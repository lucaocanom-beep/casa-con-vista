# URL pubblico del sito
NEXT_PUBLIC_SITE_URL=https://casaconvistaportorecanati.it

# Resend — invio email transazionali (form contatti + backup guida)
# Crea account su resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Mittente verificato su Resend (deve essere un dominio che possiedi)
CONTACT_FROM_EMAIL=noreply@casaconvistaportorecanati.it
# Destinatario delle richieste di contatto
CONTACT_TO_EMAIL=luca@casaconvistaportorecanati.it

# MailerLite — automazioni marketing (funnel guida)
# Account MailerLite → Integrations → API → Create new token
MAILERLITE_API_KEY=eyJhbGci...
# ID del gruppo "Guida Porto Recanati": Groups → crea gruppo → copia ID dall'URL
MAILERLITE_GROUP_ID=000000000000
